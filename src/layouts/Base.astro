---
interface Props {
  title: string
  description?: string
}
const { title, description = 'Daily NYT Spelling Bee answers with word definitions and full archive.' } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-gray-50 min-h-screen">
    <header class="bg-white border-b border-gray-200">
      <nav class="max-w-2xl mx-auto px-4 py-4 flex items-center gap-6">
        <a href="/" class="text-lg font-bold text-yellow-500 hover:text-yellow-600">🐝 SpellingBeeAnswers</a>
        <a href="/" class="text-sm text-gray-600 hover:text-gray-900">Today</a>
        <a href="/answers" class="text-sm text-gray-600 hover:text-gray-900">Archive</a>
        <a href="/hints" class="text-sm text-gray-600 hover:text-gray-900">Hints</a>
      </nav>
    </header>
    <slot />
    <footer class="max-w-2xl mx-auto px-4 py-8 mt-12 border-t border-gray-200 text-center text-sm text-gray-400">
      Not affiliated with The New York Times. For entertainment purposes only.
    </footer>
  </body>
</html>
