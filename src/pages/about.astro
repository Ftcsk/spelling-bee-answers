---
import Base from '../layouts/Base.astro'
---
<Base title="About | SpellingBeeAnswers" description="About SpellingBeeAnswers — daily NYT Spelling Bee answers, hints, and word definitions.">
  <main class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">About</h1>
    <div class="space-y-4 text-gray-700">
      <p>SpellingBeeAnswers is a fan-made resource for NYT Spelling Bee players. We publish daily answers, gradual hints, and word definitions to help you learn and enjoy the game.</p>
      <p>This site is not affiliated with or endorsed by The New York Times.</p>
      <h2 class="text-lg font-semibold text-gray-900 pt-4">What We Offer</h2>
      <ul class="list-disc pl-5 space-y-1 text-sm">
        <li>Today's complete answer list with pangrams highlighted</li>
        <li>Full archive of past puzzles</li>
        <li>Gradual hints — reveal as much or as little as you want</li>
        <li>Word definitions and part-of-speech for every answer</li>
      </ul>
    </div>
  </main>
</Base>
