---
import Base from '../../layouts/Base.astro'
import { getAllAnswers } from '../../lib/answers'

const answers = getAllAnswers()
const allWords = [...new Map(
  answers.flatMap(a => a.words).map(w => [w.word, w])
).values()].sort((a, b) => a.word.localeCompare(b.word))

const title = 'Spelling Bee Word Definitions | SpellingBeeAnswers'
---
<Base title={title} description="Browse definitions and examples for all NYT Spelling Bee words.">
  <main class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-1">Word Definitions</h1>
    <p class="text-gray-500 mb-8">All words that have appeared in NYT Spelling Bee.</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      {allWords.map(w => (
        <a href={`/words/${w.word.toLowerCase()}`}
           class={`px-3 py-2 rounded-lg border text-sm font-medium hover:bg-yellow-50 transition-colors ${
             w.isPangram ? 'border-yellow-300 bg-yellow-50 text-yellow-800' : 'border-gray-200 bg-white text-gray-700'
           }`}>
          {w.word}
          {w.isPangram && <span class="ml-1 text-xs">⭐</span>}
        </a>
      ))}
    </div>
  </main>
</Base>
