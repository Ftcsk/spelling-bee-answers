---
import Base from '../../layouts/Base.astro'
import { getTodayAnswer, formatDate } from '../../lib/answers'

const today = getTodayAnswer()
const dateLabel = formatDate(today.date)

// Group words by first letter
const byFirstLetter: Record<string, string[]> = {}
for (const w of today.words) {
  const fl = w.word[0] ?? '?'
  if (!byFirstLetter[fl]) byFirstLetter[fl] = []
  byFirstLetter[fl].push(w.word)
}

// Word length counts
const lengthCounts: Record<number, number> = {}
for (const w of today.words) {
  lengthCounts[w.word.length] = (lengthCounts[w.word.length] ?? 0) + 1
}
---
<Base title={`Spelling Bee Hints Today - ${dateLabel} | SpellingBeeAnswers`} description="Gradual hints for today's NYT Spelling Bee puzzle.">
  <main class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-1">Spelling Bee Hints</h1>
    <p class="text-gray-500 mb-8">{dateLabel}</p>

    <!-- Hint Level 1: Word counts by length -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-3">Hint 1 — Word Lengths</h2>
      <p class="text-sm text-gray-500 mb-4">How many words of each length are there?</p>
      <div class="flex flex-wrap gap-3">
        {Object.entries(lengthCounts).sort(([a],[b]) => Number(a)-Number(b)).map(([len, count]) => (
          <div class="bg-white border border-gray-200 rounded-lg px-4 py-3 text-center">
            <div class="text-2xl font-bold text-gray-900">{len}</div>
            <div class="text-xs text-gray-500">{count} word{count > 1 ? 's' : ''}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Hint Level 2: First letters -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-3">Hint 2 — Starting Letters</h2>
      <p class="text-sm text-gray-500 mb-4">How many words start with each letter?</p>
      <div class="flex flex-wrap gap-3">
        {Object.entries(byFirstLetter).sort().map(([letter, words]) => (
          <div class="bg-white border border-gray-200 rounded-lg px-4 py-3 text-center">
            <div class="text-2xl font-bold text-yellow-600">{letter}</div>
            <div class="text-xs text-gray-500">{words.length} word{words.length > 1 ? 's' : ''}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Hint Level 3: Full answers link -->
    <section class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 text-center">
      <p class="text-gray-700 mb-4">Ready to see all the answers?</p>
      <a href="/" class="inline-block bg-yellow-400 hover:bg-yellow-500 text-yellow-900 font-bold px-6 py-3 rounded-lg transition-colors">
        Show All Answers →
      </a>
    </section>
  </main>
</Base>
